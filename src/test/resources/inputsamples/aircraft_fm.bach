# [Parameter]
Low (true false)
Materials (true false)
Piston (true false)
Jet (true false)
Wood (true false)
Plastic (true false)
Engine (true false)
Cloth (true false)
Aircraft (true false)
Metal (true false)
Shoulder (true false)
High (true false)
Wing (true false)

# [Constraint]
(== [Aircraft] true)
(or (== [Wing] false) (== [Aircraft] true))
(or (== [Aircraft] false) (== [Wing] true))
(or (== [Engine] false) (== [Aircraft] true))
(or (== [Materials] false)  (== [Aircraft] true))
(or (== [Aircraft] false) (== [Materials] true))
(or (== [High] false) (== [Wing] true))
(or (== [Shoulder] false) (== [Wing] true))
(or (== [Low] false) (== [Wing] true))
(or (== [Wing] false) (== [High] true) (== [Shoulder] true) (== [Low] true))
(or (== [Jet] false) (== [Engine] true))
(or (== [Piston] false) (== [Engine] true))
(or (== [Engine] false) (== [Jet] true) (== [Piston] true))
(or (== [Jet] false) (== [Piston] false))
(or (== [Metal] false)  (== [Materials] true))
(or (== [Wood] false)  (== [Materials] true))
(or (== [Cloth] false) (== [Materials] true))
(or (== [Plastic] false) (== [Materials] true))
(or (== [Materials] false) (== [Metal] true) (== [Wood] true) (== [Cloth] true) (== [Plastic] true))
